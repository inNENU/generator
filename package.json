{
  "name": "innenu-generator",
  "version": "0.8.2",
  "description": "inNENU 生成器",
  "license": "Mr.Hope LICENSE",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:inNENU/generator.git"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./typings": {
      "types": "./dist/typings.d.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rimraf dist",
    "lint": "oxlint --fix --deny-warnings --report-unused-disable-directives && oxfmt",
    "lint:check": "oxlint --deny-warnings --report-unused-disable-directives && oxfmt --check",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build && pnpm run schema",
    "schema": "unrun scripts/generate-schema.ts",
    "test": "vitest"
  },
  "dependencies": {
    "ali-oss": "^6.23.0",
    "js-yaml": "^5.0.0",
    "upath": "^3.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mr-hope/tsconfig": "0.0.4",
    "@types/ali-oss": "6.23.3",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.13.3",
    "husky": "9.1.7",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.9",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.24.0",
    "rimraf": "6.1.3",
    "tsdown": "0.22.4",
    "typescript": "6.0.3",
    "unrun": "0.3.1",
    "vitest": "4.1.10"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.8.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^24.16.0",
      "onFail": "error"
    }
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
